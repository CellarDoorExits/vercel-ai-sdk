{
  "name": "@cellar-door/vercel-ai-sdk",
  "version": "0.1.4",
  "description": "Vercel AI SDK integration for cellar-door EXIT and ENTRY — verifiable agent departure and arrival markers",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --external cellar-door-exit --external cellar-door-entry --external zod --external ai",
    "test": "vitest run"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/CellarDoorExits/vercel-ai-sdk.git"
  },
  "homepage": "https://github.com/CellarDoorExits/vercel-ai-sdk#readme",
  "bugs": {
    "url": "https://github.com/CellarDoorExits/vercel-ai-sdk/issues"
  },
  "license": "Apache-2.0",
  "keywords": [
    "exit-protocol",
    "cellar-door",
    "vercel-ai-sdk",
    "ai-agent",
    "departure-marker",
    "verifiable-credentials",
    "agent-exit"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "ai": ">=4.0.0",
    "cellar-door-entry": ">=0.1.0",
    "cellar-door-exit": ">=0.2.0"
  },
  "devDependencies": {
    "ai": ">=4.0.0",
    "cellar-door-entry": "^0.1.0",
    "cellar-door-exit": "^0.2.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "zod": "^3.25.76"
  }
}
